@using MaleFashionApp.Entities
@{
    var postInfo = (Post)Model;
}
<style>
.one-post-id {
    display: none;
}
</style>
<!-- Hero -->
<section class="blog-hero spad">
    <div class="container text-center">
        <h2 class="fw-bold">@postInfo.Title</h2>
        <p class="one-post-id">@postInfo.Id</p>
        <p class="text-muted mb-1">
            @postInfo.Published?.ToString("MMMM dd, yyyy")
        </p>
        <p class="fs-5">@postInfo.Slogan</p>
    </div>
</section>

<!-- Post Details -->
<section class="blog-details spad">
    <div class="container">

        <!-- Image -->
        <div class="blog__details__pic text-center mb-5">
            <img src="~/@postInfo.ImgSrc" alt="@postInfo.ImgAlt" class="img-fluid rounded shadow-sm">
        </div>

        <!-- Content -->
        <div class="blog__details__text mb-4">
            @Html.Raw(postInfo.Content)
        </div>

        <!-- Categories -->
        <div class="mb-3">
            @foreach (var category in postInfo.Categories)
            {
                <a href="/blog?category=@category.Slug" class="badge bg-light text-dark me-2 px-3 py-2 shadow-sm">
                    @category.Title
                </a>
            }
        </div>

        <!-- Tags -->
        <div class="mb-5">
            @foreach (var tag in postInfo.Tags)
            {
                <a href="/blog?tag=@tag.Slug" class="tag-item text-decoration-none me-3 fs-6 text-primary">
                    #@tag.Title
                </a>
            }
        </div>

    </div>
</section>

<!-- Comments Section -->
<section style="background-color: #f1f3f5;">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card shadow-sm rounded-3">

                    <!-- Comments Header -->
                    <div class="card-body border-bottom bg-white text-center">
                        <h4 class="mb-0 fw-semibold">Comments Section</h4>
                    </div>

                    <!-- Comments List -->
                    <div class="card-body comments-container" style="background-color: #fafafa;">
                        <!-- Parent Comment -->
                        
                    </div>

                    <!-- Add Comment Form -->
                    <div class="card shadow-sm">
                        <div class="card-body bg-white">
                            <h4 class="text-center mb-4 fw-semibold">Comment Form</h4>

                            <form>
                                <div class="row">
                                    <!-- Login -->
                                    <div class="col-md-6 mb-3">
                                        <label for="login" class="form-label">Login</label>
                                        <input type="text" class="form-control" name="Login" id="login" placeholder="Enter login">
                                    </div>

                                    <!-- Email -->
                                    <div class="col-md-6 mb-3">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control" name="Email" id="email" placeholder="Enter email">
                                    </div>
                                </div>

                                <!-- Message full width -->
                                <div class="mb-3">
                                    <label for="message" class="form-label">Message</label>
                                    <textarea class="form-control" id="message" name="Message" rows="4" placeholder="Write your message..."></textarea>
                                </div>

                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary">Send</button>
                                    <button type="reset" class="btn btn-outline-secondary">Cancel</button>
                                </div>
                            </form>
                        </div>
                    </div>
                    
                </div> <!-- End Card -->
                <script src="~/js/comments.js"></script>
            </div>
        </div>
    </div>
</section>